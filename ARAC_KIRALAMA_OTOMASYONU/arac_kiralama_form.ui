  <property name="windowTitle">
   <string>Form</string>
  </property>
  <property name="styleSheet">
   <string notr="true">/* --- GENEL ARKA PLAN --- */
QWidget {
    background-color: #E3F2FD; /* Ana ekranla aynı açık mavi ton */
    font-family: &quot;Segoe UI&quot;;   /* Okunaklı modern yazı tipi */
    font-size: 13px;
}

/* --- GRUP KUTULARI (Kişisel Bilgiler vb.) --- */
QGroupBox {
    border: 2px solid #2196F3; /* Mavi Çerçeve */
    border-radius: 10px;       /* Köşeleri Yuvarlat */
    margin-top: 25px;          /* Başlık için pay */
    font-weight: bold;
    color: #0D47A1;            /* Başlık Rengi: Koyu Lacivert */
}

QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top center; /* Başlığı ortala */
    padding: 0 10px;
    background-color: #E3F2FD; /* Çizgi yazının altından geçmesin */
}

/* --- YAZI ETİKETLERİ (Ad, Soyad vb.) --- */
QLabel {
    color: #1565C0; /* Orta koyulukta mavi */
    font-weight: bold;
    border: none;
    background-color: transparent;
}

/* --- GİRİŞ KUTULARI (Text, Combo, Date) --- */
QLineEdit, QComboBox, QDateEdit, QPlainTextEdit {
    background-color: white;   /* İçi bembeyaz olsun */
    border: 1px solid #90CAF9; /* İnce mavi çerçeve */
    border-radius: 5px;
    padding: 5px;
    color: #333333;            /* Yazılan yazı koyu gri */
}

/* Kutulara tıklayınca (Odaklanınca) */
QLineEdit:focus, QComboBox:focus, QDateEdit:focus, QPlainTextEdit:focus {
    border: 2px solid #2196F3; /* Seçili kutunun çerçevesi kalınlaşsın */
}

/* --- BUTONLAR (Genel) --- */
QPushButton {
    background-color: #1976D2; /* Ana menüdeki mavi buton */
    color: white;
    border-radius: 5px;
    padding: 10px;
    font-weight: bold;
    border: none;
}

QPushButton:hover {
    background-color: #1565C0; /* Üzerine gelince koyulaşsın */
}

QPushButton:pressed {
    background-color: #0D47A1; /* Tıklayınca daha da koyu */
}</string>
  </property>
