   <property name="styleSheet">
    <string notr="true">/* --- Ana Kutu (GroupBox) Ayarları --- */
QGroupBox {
    /* Arka Plan: Çok açık, ferah bir mavi tonu */
    background-color: #FFFFFF; 
    
    /* Çerçeve: Belirgin bir mavi */
    border: 3px solid #2196F3; 
    
    /* Köşeleri yumuşat */
    border-radius: 12px;        
    
    /* Başlık yazısının çizginin üstüne gelmemesi için yukarıdan boşluk */
    margin-top: 25px;           
    
    font-weight: bold;
}

/* --- Kutunun Başlığı (Örn: Menü) --- */
QGroupBox::title {
    /* Başlığı kutunun çerçevesinin ortasına yerleştir */
    subcontrol-origin: margin;
    subcontrol-position: top center; 
    
    /* Başlığın etrafına biraz boşluk bırak */
    padding: 5px 15px;
    
    /* Başlık Yazı Rengi: Koyu, okunaklı mavi */
    color: #0D47A1; 
    
    /* Başlığın kendi arka planı (şeffaf olsun) */
    background-color: transparent;
}

/* --- Butonların Normal Hali --- */
QPushButton {
    /* Buton Rengi: Canlı, modern bir mavi */
    background-color: #1976D2; 
    
    /* Yazı Rengi: Beyaz */
    color: white;              
    
    /* Kenarlık olmasın, sadece renk olsun */
    border: none;
    
    /* Buton köşelerini hafif yuvarlat */
    border-radius: 6px;
    
    /* Butonun içi biraz geniş ve ferah olsun */
    padding: 12px;             
    
    font-size: 14px;
    font-weight: bold;
}

/* --- Butonun Üzerine Gelince (Hover) --- */
QPushButton:hover {
    /* Rengi biraz daha koyulaştır */
    background-color: #1565C0; 
}

/* --- Butona Tıklanınca (Pressed) --- */
QPushButton:pressed {
    /* Tıklama hissi için en koyu mavi tonu */
    background-color: #0D47A1; 
}</string>
