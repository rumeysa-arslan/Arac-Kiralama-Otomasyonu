     <property name="styleSheet">
      <string notr="true">/* --- GENEL SAYFA YAPISI --- */
QWidget {
    background-color: #E3F2FD; /* Ana arka plan açık mavi */
    font-family: &quot;Segoe UI&quot;, sans-serif; /* Modern yazı tipi */
    color: #333333;
}

/* --- ANA BAŞLIK (Label) --- */
QLabel {
    color: #1565C0; /* Koyu mavi başlık rengi */
    font-weight: bold;
    font-size: 16px;
    margin-bottom: 10px;
}

/* --- TABLO TASARIMI (QTableWidget) --- */
QTableWidget {
    background-color: #FFFFFF; /* Tablo içi beyaz */
    border: 2px solid #2196F3; /* Kenarlık mavi */
    border-radius: 8px; /* Köşeler yuvarlak */
    gridline-color: #BBDEFB; /* Satır çizgileri açık mavi */
    selection-background-color: #64B5F6; /* Seçili satır rengi */
    selection-color: #FFFFFF; /* Seçili yazı rengi */
}

/* --- TABLO BAŞLIKLARI (Header) --- */
QHeaderView::section {
    background-color: #1976D2; /* Başlık arka planı koyu mavi */
    color: #FFFFFF; /* Başlık yazısı beyaz */
    padding: 6px 4px; /* İç boşluk */
    border: none; /* Başlıklar arası çizgi olmasın */
    border-right: 1px solid #1565C0; /* Sadece sağda ince çizgi */
    font-weight: bold;
}

/* Tablonun sol üst köşesindeki boş kutu */
QTableCornerButton::section {
    background-color: #1976D2;
    border: none;
}

/* --- BUTONLAR (QPushButton) --- */
QPushButton {
    background-color: #1976D2; /* Buton rengi mavi */
    color: white;
    border: none;
    border-radius: 5px;
    padding: 10px 20px; /* Butonları biraz genişlet */
    font-weight: bold;
    font-size: 13px;
}

QPushButton:hover {
    background-color: #1565C0; /* Üzerine gelince koyulaşsın */
}

QPushButton:pressed {
    background-color: #0D47A1; /* Tıklayınca daha koyu */
}</string>
