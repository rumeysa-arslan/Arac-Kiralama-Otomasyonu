  <property name="styleSheet">
   <string notr="true">/* --- GENEL ARKA PLAN --- */
QWidget {
    background-color: #E3F2FD; /* Ana ekranla aynı açık mavi ton */
    font-family: &quot;Segoe UI&quot;;   /* Okunaklı modern yazı tipi */
    font-size: 13px;
    color: #333333;
}

/* --- TABLO TASARIMI (En Önemli Kısım) --- */
QTableWidget {
    background-color: white;       /* Tablo içi bembeyaz */
    border: 2px solid #2196F3;     /* Mavi Çerçeve (Diğer kutularla uyumlu) */
    border-radius: 10px;           /* Köşeleri yuvarlat */
    gridline-color: #E0E0E0;       /* Satır çizgileri çok silik gri */
    selection-background-color: #BBDEFB; /* Seçili satır açık mavi olsun */
    selection-color: #000000;      /* Seçili yazı siyah kalsın */
    padding: 5px;
}

/* --- TABLO BAŞLIKLARI (Üst Kısım) --- */
QHeaderView::section {
    background-color: #1976D2;     /* Başlıklar koyu mavi olsun */
    color: white;                  /* Başlık yazıları beyaz */
    padding: 6px;
    border: 1px solid #1565C0;     /* Aralarda ince çizgiler */
    font-weight: bold;             /* Kalın yazı */
    font-size: 14px;
}

/* Sol üst köşedeki boş kutucuk (Tablo kesişimi) */
QTableCornerButton::section {
    background-color: #1976D2;
    border: 1px solid #1565C0;
}

/* --- BUTONLAR (Senin Kodunla Aynı) --- */
QPushButton {
    background-color: #1976D2; 
    color: white;
    border-radius: 5px;
    padding: 10px;
    font-weight: bold;
    border: none;
    min-width: 100px; /* Butonlar çok dar olmasın */
}

QPushButton:hover {
    background-color: #1565C0; /* Üzerine gelince koyulaşsın */
}

QPushButton:pressed {
    background-color: #0D47A1; /* Tıklayınca daha da koyu */
}

/* --- ETİKETLER (Başlıklar vb.) --- */
QLabel {
    color: #0D47A1; /* Koyu Lacivert (Diğer sayfadaki başlık rengi) */
    font-weight: bold;
    font-size: 15px; /* Başlıklar biraz daha büyük dursun */
}</string>
